# Copy this to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars — it is gitignored.

# IMPORTANT: Do NOT put the Buildkite agent token in this file.
# Source it at apply time via an environment variable:
#
#   export TF_VAR_buildkite_agent_token=$(aws ssm get-parameter \
#     --name /buildkite/buildkite/agent-token \
#     --with-decryption --query Parameter.Value --output text \
#     --profile mockserver-build)
#
# The run.sh wrapper does this automatically.
# buildkite_agent_token = "NEVER_PUT_TOKEN_HERE"

region               = "eu-west-2"
instance_types       = "c5.2xlarge,c5.xlarge,c5a.2xlarge,c5a.xlarge,m5.2xlarge,m5.xlarge"
min_size             = 0
max_size             = 10
on_demand_percentage = 20
release_max_size     = 2
trigger_instance_types = "t3.small,t3a.small,t3.micro"
trigger_max_size       = 4

# Email address for infrastructure alerts (SNS notifications)
# Leave empty ("") to skip email subscription
alert_email = "your-email@example.com"
