  "homepage": "http://mock-server.com",
  "author": {
    "name": "James Bloom",
    "email": "jamesdbloom@gmail.com",
    "url": "http://mock-server.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mock-server/mockserver-monorepo.git",
    "directory": "mockserver-client-node"
  },
  "bugs": {
    "url": "https://github.com/mock-server/mockserver-monorepo/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 14.17.0"
  },
  "files": [
    "README.md",
    "LICENSE.md",
    "index.js",
    "index.d.ts",
    "mockServer.d.ts",
    "mockServerClient.js",
    "mockServerClient.d.ts",
    "sendRequest.js",
    "webSocketClient.js",
    "stop_MockServer.sh"
  ],
  "scripts": {
    "test": "node --test --test-force-exit --test-concurrency=1 test/no_proxy/mock_server_node_client_test.js test/with_proxy/proxy_client_node_test.js",
    "test:coverage": "c8 --check-coverage --lines 68 --functions 83 --branches 74 node --test --test-force-exit --test-concurrency=1 test/no_proxy/mock_server_node_client_test.js test/with_proxy/proxy_client_node_test.js",
    "test:browser": "npx playwright test --config test/browser/playwright.config.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "~25.9.1",
    "c8": "~11.0.0",
    "grunt-contrib-jshint": "~3.2.0",
    "grunt-exec": "~3.0.0",
    "mockserver-node": "6.1.0",
    "typescript": "~6.0.3"
  },
  "keywords": [
    "mockserver",
    "mock",
    "HTTP",
    "HTTPS",
    "testing",
    "proxy",
    "api",
    "mcp",
    "ai",
    "client"
  ],
  "dependencies": {
    "browser-or-node": "~3.0.0",
    "q": "~2.0.3",
    "websocket": "~1.0.34"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
