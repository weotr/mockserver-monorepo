<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey package specification for MockServer CLI.
  Submitted to https://community.chocolatey.org/packages via `choco push`.

  TODO(cli-release): Replace ${VERSION} once the CLI release version is known.
-->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <!-- The id must be lowercase and match the directory name on chocolatey.org -->
    <id>mockserver</id>
    <!-- TODO(cli-release): Set to actual release version -->
    <version>${VERSION}</version>
    <title>MockServer</title>
    <authors>James D Bloom</authors>
    <owners>mockserver</owners>
    <projectUrl>https://www.mock-server.com</projectUrl>
    <projectSourceUrl>https://github.com/mock-server/mockserver-monorepo</projectSourceUrl>
    <bugTrackerUrl>https://github.com/mock-server/mockserver-monorepo/issues</bugTrackerUrl>
    <docsUrl>https://www.mock-server.com/mock_server/getting_started.html</docsUrl>
    <licenseUrl>https://github.com/mock-server/mockserver-monorepo/blob/master/LICENSE.md</licenseUrl>
    <iconUrl>https://www.mock-server.com/favicon.ico</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>Mock, proxy and record HTTP(S), gRPC, and async messaging for testing</summary>
    <description>
MockServer is an open-source HTTP(S) mock server and proxy for testing.
It can mock any system you integrate with via HTTP or HTTPS, proxy requests
to record and playback, and verify requests have been made.

The `mockserver` CLI provides subcommands: run, proxy, openapi, version, help.

## Usage

```
mockserver run -p 1080
mockserver proxy --to https://api.example.com
mockserver openapi ./petstore.yaml -p 1080
```
    </description>
    <tags>mock proxy testing http https grpc api test</tags>
    <releaseNotes>https://github.com/mock-server/mockserver-monorepo/releases/tag/mockserver-${VERSION}</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
