#!/usr/bin/env bash
# Returns the latest stable version of MockServer CLI.
# Called by asdf/mise to resolve `latest` to a concrete version.

set -euo pipefail

repo="mock-server/mockserver-monorepo"

# Use the GitHub API to get the latest release (excludes pre-releases)
latest_tag=$(curl -fsSL \
  ${GITHUB_API_TOKEN:+-H "Authorization: Bearer $GITHUB_API_TOKEN"} \
  "https://api.github.com/repos/$repo/releases/latest" \
  | grep -oP '"tag_name":\s*"\Kmockserver-[^"]+' \
  | sed 's/^mockserver-//')

if [[ -z "$latest_tag" ]]; then
  echo "Failed to determine latest MockServer version" >&2
  exit 1
fi

echo "$latest_tag"
