    {
      "required": [
        "httpLlmResponse"
      ]
    },
    {
      "required": [
        "httpWebSocketResponse"
      ]
    },
    {
      "required": [
        "grpcStreamResponse"
      ]
    },
    {
      "required": [
        "grpcBidiResponse"
      ]
    },
    {
      "required": [
        "binaryResponse"
      ]
    },
    {
      "required": [
        "dnsResponse"
      ]
    },
    {
      "required": [
        "httpResponses"
      ]
    },
    {
      "required": [
        "steps"
      ]
    }
  ],
  "definitions": {
  }
