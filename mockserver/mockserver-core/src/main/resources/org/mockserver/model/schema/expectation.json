    "httpResponseClassCallback": {
      "$ref": "#/definitions/httpClassCallback"
    },
    "httpResponseObjectCallback": {
      "$ref": "#/definitions/httpObjectCallback"
    },
    "httpForward": {
      "$ref": "#/definitions/httpForward"
    },
    "httpForwardTemplate": {
      "$ref": "#/definitions/httpTemplate"
    },
    "httpForwardClassCallback": {
      "$ref": "#/definitions/httpClassCallback"
    },
    "httpForwardObjectCallback": {
      "$ref": "#/definitions/httpObjectCallback"
    },
    "httpOverrideForwardedRequest": {
      "$ref": "#/definitions/httpOverrideForwardedRequest"
    },
    "httpForwardValidateAction": {
      "$ref": "#/definitions/httpForwardValidateAction"
    },
    "httpForwardWithFallback": {
      "$ref": "#/definitions/httpForwardWithFallback"
    },
    "httpError": {
      "$ref": "#/definitions/httpError"
    },
    "httpSseResponse": {
      "$ref": "#/definitions/httpSseResponse"
    },
    "httpLlmResponse": {
      "$ref": "#/definitions/httpLlmResponse"
    },
    "httpWebSocketResponse": {
      "$ref": "#/definitions/httpWebSocketResponse"
    },
    "grpcStreamResponse": {
      "$ref": "#/definitions/grpcStreamResponse"
    },
    "grpcBidiResponse": {
      "$ref": "#/definitions/grpcBidiResponse"
    },
    "binaryResponse": {
      "$ref": "#/definitions/binaryResponse"
    },
    "dnsResponse": {
      "$ref": "#/definitions/dnsResponse"
    },
    "beforeActions": {
      "oneOf": [
        { "$ref": "#/definitions/afterAction" },
        { "type": "array", "items": { "$ref": "#/definitions/afterAction" }, "minItems": 1 }
      ]
    },
    "afterActions": {
      "oneOf": [
        { "$ref": "#/definitions/afterAction" },
        { "type": "array", "items": { "$ref": "#/definitions/afterAction" }, "minItems": 1 }
      ]
    },
    "scenarioName": {
      "type": "string"
    },
    "scenarioState": {
      "type": "string"
    },
    "newScenarioState": {
      "type": "string"
    },
    "httpResponses": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/httpResponse"
      },
      "minItems": 1
    },
    "responseMode": {
      "enum": [
        "SEQUENTIAL",
        "RANDOM"
      ]
    },
    "times": {
      "$ref": "#/definitions/times"
    },
    "timeToLive": {
      "$ref": "#/definitions/timeToLive"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/expectationStep"
      },
      "minItems": 1
    },
    "timestamp": {
      "description": "added to allow request and response log output to be used to create expectations",
      "type": "string"
    }
  },
  "anyOf": [
