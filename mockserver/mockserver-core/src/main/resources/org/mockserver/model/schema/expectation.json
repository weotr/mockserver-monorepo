      "type": "string"
    },
    "priority": {
      "type": "integer"
    },
    "percentage": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "chaos": {
      "$ref": "#/definitions/httpChaosProfile"
    },
    "httpRequest": {
      "$ref": "#/definitions/requestDefinition"
    },
    "httpResponse": {
      "$ref": "#/definitions/httpResponse"
    },
    "httpResponseTemplate": {
      "$ref": "#/definitions/httpTemplate"
