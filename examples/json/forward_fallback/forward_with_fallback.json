{
  "httpRequest": {
    "path": "/api/backend"
  },
  "httpForwardWithFallback": {
    "httpForward": {
      "scheme": "HTTPS",
      "host": "backend.example.com",
      "port": 443
    },
    "fallbackResponse": {
      "statusCode": 503,
      "body": "service temporarily unavailable"
    },
    "fallbackOnStatusCodes": [500, 502, 503],
    "fallbackOnTimeout": true
  }
}
